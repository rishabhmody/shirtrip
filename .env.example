# ShirtRip Configuration
SHIRTRIP_DEVICE=cuda          # "cuda" or "cpu"
SHIRTRIP_MODEL_CACHE_DIR=models_cache
SHIRTRIP_MAX_UPLOAD_MB=20
SHIRTRIP_LOG_LEVEL=INFO
SHIRTRIP_MAX_IMAGE_DIMENSION=2048
SHIRTRIP_USE_SAM2=true

# Grounding DINO + SAM graphic detection
# Local (4GB VRAM): use tiny/base (default)
SHIRTRIP_DINO_MODEL_ID=IDEA-Research/grounding-dino-tiny
SHIRTRIP_SAM_MODEL_ID=facebook/sam-vit-base
SHIRTRIP_SEQUENTIAL_GPU_LOADING=true

# Colab T4 (16GB VRAM): use base/huge for better accuracy
# SHIRTRIP_DINO_MODEL_ID=IDEA-Research/grounding-dino-base
# SHIRTRIP_SAM_MODEL_ID=facebook/sam-vit-huge
# SHIRTRIP_SEQUENTIAL_GPU_LOADING=false

SHIRTRIP_GRAPHIC_PROMPT="graphic design . text . logo . printed artwork"
SHIRTRIP_DINO_BOX_THRESHOLD=0.3
SHIRTRIP_DINO_TEXT_THRESHOLD=0.25
